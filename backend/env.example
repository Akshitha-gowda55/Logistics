CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: Mapbox Directions API for real road geometries on GET /api/v1/routes/route-dashboard
MAPBOX_ACCESS_TOKEN=
# Set true only when you need live Mapbox routes (slower); default India demo uses static polylines
USE_MAPBOX_DIRECTIONS=false

# Prefer OpenRouteService or GraphHopper for road-following routes (recommended / fastest / shortest lanes)
OPENROUTESERVICE_API_KEY=
GRAPHHOPPER_API_KEY=
GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1

# Twilio SMS (optional). Without these, SMS is logged only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_PHONE_OPERATIONS=
SMS_PHONE_INVENTORY=
SMS_PHONE_SUPPLIER=
SMS_PHONE_EXECUTIVE=
